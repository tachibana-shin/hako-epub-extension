{
  "name": "hako-epub",
  "displayName": "Hako EPub",
  "version": "0.6.2",
  "private": true,
  "description": "Tiện ích tải EPub trên website",
  "type": "module",
  "scripts": {
    "dev": "npm run clear && cross-env NODE_ENV=development run-p 'dev:*'",
    "dev-firefox": "npm run clear && cross-env NODE_ENV=development EXTENSION=firefox run-p dev:*",
    "dev:prepare": "bun scripts/prepare.ts",
    "dev:background": "npm run build:background -- --mode development",
    "dev:web": "vite",
    "dev:js": "npm run build:js -- --mode development",
    "dev:css-ce": "bun scripts/build-ce-css.ts dev",
    "dev:inject": "npm run build:inject -- --mode development",
    "build": "cross-env NODE_ENV=production run-s clear build:web build:prepare build:background build:js build:css-ce build:inject",
    "build-firefox": "cross-env NODE_ENV=production EXTENSION=firefox run-s build:web build:prepare build:background build:js build:css-ce build:inject",
    "build:prepare": "bun scripts/prepare.ts",
    "build:background": "vite build --config vite.config.background.mts",
    "build:web": "vite build",
    "build:js": "vite build --config vite.config.content.mts",
    "build:css-ce": "bun scripts/build-ce-css.ts build",
    "build:inject": "vite build --config vite.config.content-inject.mts",
    "pack": "cross-env NODE_ENV=production run-p pack:*",
    "pack:zip": "rimraf extension.zip && jszip-cli add extension/* -o ./extension.zip",
    "pack:crx": "crx pack extension -o ./extension.crx",
    "pack:xpi": "cross-env WEB_EXT_ARTIFACTS_DIR=./ web-ext build --source-dir ./extension --filename extension.xpi --overwrite-dest",
    "pack-firefox": "cross-env NODE_ENV=production run-p pack-firefox:*",
    "pack-firefox:zip": "rimraf extension-firefox.zip && jszip-cli add extension/* -o ./extension-firefox.zip",
    "pack-firefox:crx": "crx pack extension -o ./extension-firefox.crx",
    "pack-firefox:xpi": "cross-env WEB_EXT_ARTIFACTS_DIR=./ web-ext build --source-dir ./extension --filename extension-firefox.xpi --overwrite-dest",
    "start:chromium": "web-ext run --source-dir ./extension --target=chromium",
    "start:firefox": "web-ext run --source-dir ./extension --target=firefox-desktop",
    "clear": "rimraf --glob extension/dist extension/manifest.json 'extension.*'",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "postinstall": "simple-git-hooks",
    "typecheck": "tsc --noEmit",
    "update-readme": "bun scripts/update-readme.ts",
    "semantic-release": "semantic-release",
    "release": "bun update-readme && git add README.md && bun run semantic-release"
  },
  "dependencies": {
    "@ameinhardt/unocss-preset-daisy": "^1.1.8",
    "@fcanvas/communicate": "^1.1.7",
    "@unocss/preset-wind4": "^66.6.8",
    "@vueuse/integrations": "^14.3.0",
    "cheerio": "^1.2.0",
    "epub-gen-memory": "^1.1.2",
    "file-saver": "^2.0.5",
    "html-minifier-terser": "^7.2.0",
    "idb-keyval": "^6.2.2",
    "naive-ui": "^2.44.1",
    "p-limit": "^7.3.0",
    "ts-retry": "^6.0.0",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@ffflorian/jszip-cli": "^3.16.2",
    "@iconify/json": "^2.2.476",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/file-saver": "^2.0.7",
    "@types/fs-extra": "^11.0.4",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^25.9.1",
    "@types/webextension-polyfill": "^0.12.5",
    "@unocss/reset": "^66.6.8",
    "@unocss/rule-utils": "^66.6.8",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.34",
    "@vue/test-utils": "^2.4.10",
    "@vueuse/core": "^14.3.0",
    "ansis": "^4.3.0",
    "bumpp": "^11.1.0",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "crx": "^5.0.1",
    "fs-extra": "^11.3.5",
    "jsdom": "^29.1.1",
    "kolorist": "^1.8.0",
    "lightningcss": "^1.32.0",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "semantic-release": "^25.0.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.13",
    "vite-plugin-arraybuffer": "^0.1.4",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-plugin-remove-console": "^2.2.0",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "vue-demi": "^0.14.10",
    "web-ext": "^10.1.0",
    "webext-bridge": "^6.0.1",
    "webextension-polyfill": "^0.12.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bun oxlint --fix"
  },
  "trustedDependencies": [
    "spawn-sync",
    "unrs-resolver"
  ]
}
