{
  "branches": ["main"],
  "repositoryUrl": "https://github.com/tachibana-shin/hako-epub-extension.git",
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "README.md", "package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "generateReleaseNotes": true,
        "assets": [
          {
            "path": "chromium.crx",
            "label": "Chromium CRX"
          },
          {
            "path": "chromium.xpi",
            "label": "Chromium XPI"
          },
          {
            "path": "chromium.zip",
            "label": "Chromium Zip"
          },
          {
            "path": "firefox.crx",
            "label": "Firefox CRX"
          },
          {
            "path": "firefox.xpi",
            "label": "Firefox XPI"
          },
          {
            "path": "firefox.zip",
            "label": "Firefox Zip"
          }
        ]
      }
    ]
  ]
}
